generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  OWNER
  ADMIN
  PRODUCT_OWNER
  ENGINEERING_MANAGER
  DEVELOPER
  STAKEHOLDER
}

enum SprintPlanStatus {
  GENERATING
  PENDING_REVIEW
  APPROVED
  REJECTED
  REGENERATING
  SYNCING
  SYNCED
  SYNCED_PARTIAL
  UNDONE
  EXPIRED
}

enum WorkItemStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CLOSED
}

enum PRStatus {
  OPEN
  AWAITING_REVIEW
  CHANGES_REQUESTED
  APPROVED
  MERGED
  CLOSED
}

enum CIStatus {
  PASSING
  FAILING
  PENDING
  UNKNOWN
}

enum HealthSignalType {
  BURNOUT_RISK
  VELOCITY_VARIANCE
  STALLED_TICKET
  REVIEW_LAG
  CI_FAILURE
  AFTER_HOURS
  INACTIVITY
  CAPACITY_OVERLOAD
}

enum HealthSeverity {
  GREEN
  AMBER
  RED
}

enum NotificationChannel {
  SLACK
  TEAMS
  EMAIL
  IN_APP
}

enum SourceTool {
  JIRA
  ADO
  GITHUB
  NOTION
  LINEAR
}

enum ActivityEventType {
  COMMIT_PUSHED
  PR_OPENED
  PR_UPDATED
  PR_REVIEWED
  PR_MERGED
  PR_CLOSED
  CI_RUN
  TICKET_STATUS_CHANGED
  TICKET_ASSIGNED
}

enum BlockerStatus {
  OPEN
  ACKNOWLEDGED
  ESCALATED
  RESOLVED
}

// ============================================================================
// CORE ENTITIES
// ============================================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  timezone    String   @default("America/New_York")
  workingHoursStart String @default("09:00") @map("working_hours_start")
  workingHoursEnd   String @default("17:00") @map("working_hours_end")
  standupTime       String @default("09:30") @map("standup_time")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users              User[]
  teamMembers        TeamMember[]
  workItems          WorkItem[]
  iterations         Iteration[]
  repositories       Repository[]
  sprintPlans        SprintPlan[]
  standupReports     StandupReport[]
  teamDigests        TeamStandupDigest[]
  healthSignals      HealthSignal[]
  burnoutAlerts      BurnoutAlert[]
  retrospectives     Retrospective[]
  auditLogEntries    AuditLogEntry[]
  activityEvents     ActivityEvent[]
  connections        ToolConnection[]

  @@map("organizations")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  fullName         String    @map("full_name")
  avatarUrl        String?   @map("avatar_url")
  role             UserRole  @default(DEVELOPER)
  supabaseUserId   String    @unique @map("supabase_user_id")
  organizationId   String    @map("organization_id")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization          Organization           @relation(fields: [organizationId], references: [id])
  notificationPrefs     NotificationPreference[]
  auditLogEntries       AuditLogEntry[]        @relation("actor")

  @@map("users")
}

model ToolConnection {
  id               String     @id @default(cuid())
  organizationId   String     @map("organization_id")
  sourceTool       SourceTool @map("source_tool")
  accessToken      String     @map("access_token")
  refreshToken     String?    @map("refresh_token")
  tokenExpiresAt   DateTime?  @map("token_expires_at")
  webhookSecret    String?    @map("webhook_secret")
  lastSyncAt       DateTime?  @map("last_sync_at")
  syncStatus       String     @default("idle") @map("sync_status")
  config           Json?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, sourceTool])
  @@map("tool_connections")
}

// ============================================================================
// WORK MANAGEMENT ENTITIES
// ============================================================================

model TeamMember {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  externalId      String   @map("external_id")
  email           String
  displayName     String   @map("display_name")
  avatarUrl       String?  @map("avatar_url")
  skillTags       String[] @map("skill_tags")
  defaultCapacity Float    @default(40) @map("default_capacity")
  slackUserId     String?  @map("slack_user_id")
  teamsUserId     String?  @map("teams_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id])
  workItems        WorkItem[]
  planAssignments  PlanAssignment[]
  standupReports   StandupReport[]
  velocityProfiles VelocityProfile[]
  healthSignals    HealthSignal[]
  burnoutAlerts    BurnoutAlert[]
  activityEvents   ActivityEvent[]
  commits          Commit[]
  pullRequests     PullRequest[]

  @@unique([organizationId, externalId])
  @@map("team_members")
}

model WorkItem {
  id              String         @id @default(cuid())
  organizationId  String         @map("organization_id")
  externalId      String         @map("external_id")
  sourceTool      SourceTool     @map("source_tool")
  title           String
  description     String?
  status          WorkItemStatus @default(BACKLOG)
  storyPoints     Float?         @map("story_points")
  priority        Int            @default(0)
  type            String         @default("story")
  labels          String[]
  acceptanceCriteria String?     @map("acceptance_criteria")
  epicId          String?        @map("epic_id")
  iterationId     String?        @map("iteration_id")
  assigneeId      String?        @map("assignee_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id])
  iteration       Iteration?      @relation(fields: [iterationId], references: [id])
  assignee        TeamMember?     @relation(fields: [assigneeId], references: [id])
  planAssignments PlanAssignment[]
  pullRequests    PullRequest[]

  @@unique([organizationId, externalId, sourceTool])
  @@map("work_items")
}

model Iteration {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  externalId     String   @map("external_id")
  sourceTool     SourceTool @map("source_tool")
  name           String
  goal           String?
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  state          String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  workItems    WorkItem[]
  sprintPlans  SprintPlan[]

  @@unique([organizationId, externalId, sourceTool])
  @@map("iterations")
}

// ============================================================================
// GITHUB ENTITIES
// ============================================================================

model Repository {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  externalId     String   @map("external_id")
  name           String
  fullName       String   @map("full_name")
  defaultBranch  String   @default("main") @map("default_branch")
  url            String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  pullRequests PullRequest[]
  commits      Commit[]

  @@unique([organizationId, externalId])
  @@map("repositories")
}

model PullRequest {
  id             String   @id @default(cuid())
  repositoryId   String   @map("repository_id")
  externalId     String   @map("external_id")
  number         Int
  title          String
  status         PRStatus @default(OPEN)
  authorId       String?  @map("author_id")
  reviewers      String[]
  ciStatus       CIStatus @default(UNKNOWN) @map("ci_status")
  linkedWorkItemId String? @map("linked_work_item_id")
  url            String
  createdExternalAt DateTime @map("created_external_at")
  mergedAt       DateTime?  @map("merged_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  repository     Repository  @relation(fields: [repositoryId], references: [id])
  author         TeamMember? @relation(fields: [authorId], references: [id])
  linkedWorkItem WorkItem?   @relation(fields: [linkedWorkItemId], references: [id])

  @@unique([repositoryId, externalId])
  @@map("pull_requests")
}

model Commit {
  id             String   @id @default(cuid())
  repositoryId   String   @map("repository_id")
  sha            String
  message        String
  authorId       String?  @map("author_id")
  branch         String
  linkedTicketIds String[] @map("linked_ticket_ids")
  filesChanged   Int      @default(0) @map("files_changed")
  committedAt    DateTime @map("committed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  repository Repository  @relation(fields: [repositoryId], references: [id])
  author     TeamMember? @relation(fields: [authorId], references: [id])

  @@unique([repositoryId, sha])
  @@map("commits")
}

// ============================================================================
// ACTIVITY ENGINE
// ============================================================================

model ActivityEvent {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  teamMemberId   String            @map("team_member_id")
  eventType      ActivityEventType @map("event_type")
  sourceTool     SourceTool        @map("source_tool")
  externalId     String?           @map("external_id")
  linkedTicketId String?           @map("linked_ticket_id")
  metadata       Json?
  isAfterHours   Boolean           @default(false) @map("is_after_hours")
  isWeekend      Boolean           @default(false) @map("is_weekend")
  occurredAt     DateTime          @map("occurred_at")
  createdAt      DateTime          @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  teamMember   TeamMember   @relation(fields: [teamMemberId], references: [id])

  @@index([organizationId, teamMemberId, occurredAt])
  @@index([organizationId, occurredAt])
  @@map("activity_events")
}

// ============================================================================
// STANDUP ENGINE
// ============================================================================

model StandupReport {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  teamMemberId    String   @map("team_member_id")
  iterationId     String?  @map("iteration_id")
  reportDate      DateTime @map("report_date")
  completedItems  Json     @map("completed_items")
  inProgressItems Json     @map("in_progress_items")
  blockers        Json
  narrativeText   String   @map("narrative_text")
  acknowledged    Boolean  @default(false)
  acknowledgedAt  DateTime? @map("acknowledged_at")
  developerNote   String?  @map("developer_note")
  isInactive      Boolean  @default(false) @map("is_inactive")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  teamMember   TeamMember   @relation(fields: [teamMemberId], references: [id])
  blockerFlags BlockerFlag[]

  @@unique([organizationId, teamMemberId, reportDate])
  @@map("standup_reports")
}

model TeamStandupDigest {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  iterationId     String?  @map("iteration_id")
  digestDate      DateTime @map("digest_date")
  sprintPacing    Float    @map("sprint_pacing")
  acknowledgedPct Float    @map("acknowledged_pct")
  sprintHealth    HealthSeverity @map("sprint_health")
  atRiskItems     Json     @map("at_risk_items")
  blockerCount    Int      @map("blocker_count")
  summaryText     String   @map("summary_text")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, digestDate])
  @@map("team_standup_digests")
}

model BlockerFlag {
  id               String        @id @default(cuid())
  standupReportId  String        @map("standup_report_id")
  description      String
  ticketReference  String?       @map("ticket_reference")
  status           BlockerStatus @default(OPEN)
  flaggedAt        DateTime      @default(now()) @map("flagged_at")
  resolvedAt       DateTime?     @map("resolved_at")

  standupReport StandupReport @relation(fields: [standupReportId], references: [id])

  @@map("blocker_flags")
}

// ============================================================================
// SPRINT PLANNING ENGINE
// ============================================================================

model SprintPlan {
  id              String           @id @default(cuid())
  organizationId  String           @map("organization_id")
  iterationId     String           @map("iteration_id")
  status          SprintPlanStatus @default(GENERATING)
  confidenceScore Float?           @map("confidence_score")
  riskSummary     String?          @map("risk_summary")
  totalStoryPoints Float?          @map("total_story_points")
  unplannedItems  Json?            @map("unplanned_items")
  aiModelUsed     String?          @map("ai_model_used")
  rejectionFeedback String?        @map("rejection_feedback")
  approvedById    String?          @map("approved_by_id")
  approvedAt      DateTime?        @map("approved_at")
  syncedAt        DateTime?        @map("synced_at")
  undoAvailableUntil DateTime?     @map("undo_available_until")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id])
  iteration       Iteration        @relation(fields: [iterationId], references: [id])
  assignments     PlanAssignment[]

  @@map("sprint_plans")
}

model PlanAssignment {
  id              String   @id @default(cuid())
  sprintPlanId    String   @map("sprint_plan_id")
  workItemId      String   @map("work_item_id")
  teamMemberId    String   @map("team_member_id")
  storyPoints     Float    @map("story_points")
  confidenceScore Float    @map("confidence_score")
  rationale       String
  riskFlags       String[] @map("risk_flags")
  skillMatch      Json?    @map("skill_match")
  isHumanEdited   Boolean  @default(false) @map("is_human_edited")
  createdAt       DateTime @default(now()) @map("created_at")

  sprintPlan SprintPlan @relation(fields: [sprintPlanId], references: [id])
  workItem   WorkItem   @relation(fields: [workItemId], references: [id])
  teamMember TeamMember @relation(fields: [teamMemberId], references: [id])

  @@map("plan_assignments")
}

// ============================================================================
// ANALYTICS & HEALTH
// ============================================================================

model VelocityProfile {
  id             String   @id @default(cuid())
  teamMemberId   String   @map("team_member_id")
  iterationId    String?  @map("iteration_id")
  plannedSP      Float    @map("planned_sp")
  completedSP    Float    @map("completed_sp")
  rollingAverage Float?   @map("rolling_average")
  byTicketType   Json?    @map("by_ticket_type")
  isColdStart    Boolean  @default(false) @map("is_cold_start")
  recordedAt     DateTime @default(now()) @map("recorded_at")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id])

  @@map("velocity_profiles")
}

model HealthSignal {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  teamMemberId   String           @map("team_member_id")
  signalType     HealthSignalType @map("signal_type")
  severity       HealthSeverity
  message        String
  metadata       Json?
  resolvedAt     DateTime?        @map("resolved_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  teamMember   TeamMember   @relation(fields: [teamMemberId], references: [id])

  @@index([organizationId, createdAt])
  @@map("health_signals")
}

model BurnoutAlert {
  id                  String         @id @default(cuid())
  organizationId      String         @map("organization_id")
  teamMemberId        String         @map("team_member_id")
  severity            HealthSeverity
  capacityUtilization Float          @map("capacity_utilization")
  consecutiveSprints  Int            @map("consecutive_sprints")
  afterHoursFrequency Float          @map("after_hours_frequency")
  acknowledgedAt      DateTime?      @map("acknowledged_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  teamMember   TeamMember   @relation(fields: [teamMemberId], references: [id])

  @@map("burnout_alerts")
}

// ============================================================================
// RETROSPECTIVE
// ============================================================================

model Retrospective {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  iterationId      String?  @map("iteration_id")
  whatWentWell      Json     @map("what_went_well")
  whatDidntGoWell   Json     @map("what_didnt_go_well")
  rootCauseAnalysis Json?    @map("root_cause_analysis")
  isDraft          Boolean  @default(true) @map("is_draft")
  finalizedAt      DateTime? @map("finalized_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  actionItems  RetroActionItem[]

  @@map("retrospectives")
}

model RetroActionItem {
  id              String    @id @default(cuid())
  retrospectiveId String    @map("retrospective_id")
  title           String
  assigneeId      String?   @map("assignee_id")
  dueDate         DateTime? @map("due_date")
  status          String    @default("open")
  isCarryForward  Boolean   @default(false) @map("is_carry_forward")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  retrospective Retrospective @relation(fields: [retrospectiveId], references: [id])

  @@map("retro_action_items")
}

// ============================================================================
// AUDIT LOG (IMMUTABLE)
// ============================================================================

model AuditLogEntry {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  actorId        String   @map("actor_id")
  actorRole      UserRole @map("actor_role")
  eventType      String   @map("event_type")
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  beforeState    Json?    @map("before_state")
  afterState     Json?    @map("after_state")
  sourceChannel  String?  @map("source_channel")
  success        Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User         @relation("actor", fields: [actorId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, eventType])
  @@map("audit_log_entries")
}

// ============================================================================
// NOTIFICATION PREFERENCES
// ============================================================================

model NotificationPreference {
  id             String              @id @default(cuid())
  userId         String              @map("user_id")
  notificationType String            @map("notification_type")
  channels       NotificationChannel[]
  enabled        Boolean             @default(true)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, notificationType])
  @@map("notification_preferences")
}
