# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase Service Role (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Integration Layer — OAuth Credentials
# ============================================================================

# Jira Cloud OAuth 2.0 (3-legged)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/api/integrations/jira/auth

# Azure DevOps OAuth (Azure AD)
ADO_CLIENT_ID=
ADO_CLIENT_SECRET=
ADO_REDIRECT_URI=http://localhost:3000/api/integrations/ado/auth
ADO_TENANT_ID=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Token Encryption (AES-256-GCM, 32-byte hex key)
INTEGRATION_ENCRYPTION_KEY=

# Webhook Secrets (per-connection defaults)
JIRA_WEBHOOK_SECRET=
ADO_WEBHOOK_SECRET=
