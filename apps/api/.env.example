# =============================================================================
# Plan2Sprint FastAPI Backend — Environment Variables
# Copy this to .env and fill in the values
# =============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.your-project.supabase.co:5432/postgres

# Integration OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/integrations/jira/auth/callback
ADO_CLIENT_ID=
ADO_CLIENT_SECRET=
ADO_TENANT_ID=common
ADO_REDIRECT_URI=http://localhost:8000/api/integrations/ado/auth/callback

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/integrations/slack/callback
SLACK_BOT_SCOPES=chat:write,im:write,channels:read,users:read,users:read.email

# Microsoft Teams Integration
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=common
TEAMS_REDIRECT_URI=http://localhost:8000/api/integrations/teams/callback

# Token encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
INTEGRATION_ENCRYPTION_KEY=

# Frontend URL (for OAuth redirect back to app)
FRONTEND_URL=http://localhost:3000

# App
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true
